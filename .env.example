PORT=3000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
VITE_CCP_ACCOUNT_NUMBER=
VITE_CCP_CARD_NUMBER=
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
VITE_SUPPORT_WHATSAPP=
# Public site URL for SEO / sitemap / OG (custom domain preferred — apex)
VITE_SITE_URL=https://hallaqi.app
SITE_URL=https://hallaqi.app

# Generative AI — server-owned keys (never prefix with VITE_)
VITE_AI_ENDPOINT=/api/ai/advice
VITE_AI_PROVIDER=groq
AI_GENERATION_ENABLED=true
# Opt-in image generation (costly). Leave false/unset at soft launch.
AI_IMAGE_GENERATION_ENABLED=false
# Prefer Groq (free gsk_…) or set XAI_API_KEY (xai-…) for Grok. Model must match provider.
AI_TEXT_MODEL=llama-3.3-70b-versatile
# For xAI Grok use: AI_TEXT_MODEL=grok-3-latest
AI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
GROQ_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Stripe (server) — only when card payments go live
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional analytics / error tooling
# SENTRY_DSN=
